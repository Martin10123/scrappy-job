APP_ENV=development
APP_DEBUG=true

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobtrend
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/jobtrend

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_this_password

# Logging
LOG_LEVEL=INFO
